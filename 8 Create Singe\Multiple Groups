---
- hosts: all
  connection: ssh

  tasks:
    - name: Create a new group
      group: name=India state=present

    - name: Create an another group
      group:
        name: US
        state: present

    - name: Create multiple groups
      group: name={{item}} state=present
      with_items:
        - Russia
        - China
        - Japan
        - Nepal
        - France
...
